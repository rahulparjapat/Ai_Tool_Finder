# ==============================================================================
# .gitignore
# ------------------------------------------------------------------------------
# Files and folders that should never be committed: build output, installed
# dependencies, local caches, editor/OS artifacts, and any temporary QA
# screenshots taken during development.
# ==============================================================================

# Astro build output (regenerated by `npm run build`, never edit by hand)
dist/

# Astro's generated type-checking cache
.astro/

# Installed npm dependencies (restored via `npm install` from package-lock.json)
node_modules/

# npm/yarn/pnpm debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment variable files (never commit secrets)
.env
.env.production

# OS-specific files
.DS_Store
Thumbs.db

# Editor/IDE folders
.idea/
*.swp

# Ad-hoc QA screenshots taken during development/visual verification
_qa/
_screenshots/
