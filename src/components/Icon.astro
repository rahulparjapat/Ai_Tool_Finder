---
// ============================================================================
// Icon.astro
// ----------------------------------------------------------------------------
// A single, dependency-free, monochrome icon component. Every icon is a hand
// authored inline SVG (stroke-based, "currentColor") so:
//   1. No icon library dependency is needed (keeps the project zero-dependency
//      and avoids any licensing questions around third-party icon sets).
//   2. Icons always inherit the surrounding text color -> guarantees the
//      "non-colour icons" requirement everywhere, automatically.
//   3. No extra network request or image file — icons are inlined as markup,
//      which is best for performance and avoids layout shift.
//
// Usage: <Icon name="search" class="h-5 w-5" />
// ============================================================================
import type { IconName } from "../lib/icons";

interface Props {
  /** Which icon to render — must match a key in ICONS below. */
  name: IconName;
  /** Extra classes, e.g. sizing (h-5 w-5) or color (text-neutral-500). */
  class?: string;
}

const { name, class: className = "h-5 w-5" } = Astro.props;

// Each entry is the <path>/<circle> markup for a 0-0-24-24 viewBox outline
// icon, drawn at stroke-width 1.5 in a simple, minimal geometric style.
const ICONS = {
  // --- category icons ---
  chat: `<path d="M4.5 5.25h15a1.5 1.5 0 0 1 1.5 1.5v8.25a1.5 1.5 0 0 1-1.5 1.5H9.31l-3.56 3.19a.375.375 0 0 1-.625-.28V16.5H4.5a1.5 1.5 0 0 1-1.5-1.5V6.75a1.5 1.5 0 0 1 1.5-1.5Z" stroke-linecap="round" stroke-linejoin="round"/>`,
  pencil: `<path d="M16.86 4.49a1.9 1.9 0 0 1 2.69 2.69L8.5 18.23l-4 1 1-4L16.86 4.49Z" stroke-linecap="round" stroke-linejoin="round"/>`,
  image: `<rect x="3.75" y="4.5" width="16.5" height="15" rx="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="8.5" cy="9.5" r="1.5"/><path d="M4.5 16.5 9 12l3 3 4-4.5 3.5 3.5" stroke-linecap="round" stroke-linejoin="round"/>`,
  video: `<rect x="3" y="6" width="13.5" height="12" rx="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M16.5 10.5 21 8v8l-4.5-2.5" stroke-linecap="round" stroke-linejoin="round"/>`,
  microphone: `<rect x="9" y="3" width="6" height="11" rx="3" stroke-linecap="round" stroke-linejoin="round"/><path d="M5.5 11.5a6.5 6.5 0 0 0 13 0M12 18v3" stroke-linecap="round" stroke-linejoin="round"/>`,
  code: `<path d="M8.25 8.25 4.5 12l3.75 3.75M15.75 8.25 19.5 12l-3.75 3.75M13 5l-2 14" stroke-linecap="round" stroke-linejoin="round"/>`,
  briefcase: `<rect x="3" y="7.5" width="18" height="12" rx="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M8.5 7.5V6a1.5 1.5 0 0 1 1.5-1.5h4A1.5 1.5 0 0 1 15.5 6v1.5M3 12.75h18" stroke-linecap="round" stroke-linejoin="round"/>`,
  search: `<circle cx="10.5" cy="10.5" r="6.75" stroke-linecap="round" stroke-linejoin="round"/><path d="m20.25 20.25-4.86-4.86" stroke-linecap="round" stroke-linejoin="round"/>`,
  megaphone: `<path d="M3 10.5v3a1.5 1.5 0 0 0 1.5 1.5H6l1 5 2-.5-.75-4.5H10l7 3.5v-13l-7 3.5H4.5A1.5 1.5 0 0 0 3 10.5Z" stroke-linecap="round" stroke-linejoin="round"/>`,
  cube: `<path d="M12 3 4 7.5v9L12 21l8-4.5v-9L12 3Z" stroke-linecap="round" stroke-linejoin="round"/><path d="M4 7.5 12 12l8-4.5M12 12v9" stroke-linecap="round" stroke-linejoin="round"/>`,
  swatch: `<rect x="3.75" y="3.75" width="7.5" height="16.5" rx="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M14.5 6 20 11.5l-6 6-3-3" stroke-linecap="round" stroke-linejoin="round"/>`,
  workflow: `<circle cx="5.5" cy="6" r="2.25" stroke-linecap="round" stroke-linejoin="round"/><circle cx="18.5" cy="6" r="2.25" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="18" r="2.25" stroke-linecap="round" stroke-linejoin="round"/><path d="M7.4 7.3 10.5 16M16.6 7.3 13.5 16M7.75 6h8.5" stroke-linecap="round" stroke-linejoin="round"/>`,
  presentation: `<rect x="3" y="4.5" width="18" height="12" rx="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M9 20.5 12 17l3 3.5M12 16.5v-3" stroke-linecap="round" stroke-linejoin="round"/>`,
  headset: `<path d="M4.5 13.5V12a7.5 7.5 0 0 1 15 0v1.5" stroke-linecap="round" stroke-linejoin="round"/><rect x="3" y="13.5" width="4" height="6" rx="1.5" stroke-linecap="round" stroke-linejoin="round"/><rect x="17" y="13.5" width="4" height="6" rx="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M19 19.5a4 4 0 0 1-4 3h-2" stroke-linecap="round" stroke-linejoin="round"/>`,
  "academic-cap": `<path d="M12 4.5 2.5 9l9.5 4.5L21.5 9 12 4.5Z" stroke-linecap="round" stroke-linejoin="round"/><path d="M6 11.25V16c0 1.5 2.5 3 6 3s6-1.5 6-3v-4.75" stroke-linecap="round" stroke-linejoin="round"/>`,
  currency: `<circle cx="12" cy="12" r="8.25" stroke-linecap="round" stroke-linejoin="round"/><path d="M12 7.5v9M14.5 9.75c0-1-1-1.75-2.5-1.75s-2.5.75-2.5 1.75 1 1.5 2.5 1.75 2.5.9 2.5 1.9-1 1.85-2.5 1.85-2.5-.65-2.5-1.6" stroke-linecap="round" stroke-linejoin="round"/>`,
  // --- generic UI icons ---
  "arrow-right": `<path d="M4.5 12h15M14 6.5l5.5 5.5-5.5 5.5" stroke-linecap="round" stroke-linejoin="round"/>`,
  "external-link": `<path d="M14 4.5h5.5V10M19.5 4.5 10.5 13.5M18 14v4a1.5 1.5 0 0 1-1.5 1.5h-10A1.5 1.5 0 0 1 5 18V8a1.5 1.5 0 0 1 1.5-1.5h4" stroke-linecap="round" stroke-linejoin="round"/>`,
  check: `<path d="M4.5 12.75 9 17.25 19.5 6.75" stroke-linecap="round" stroke-linejoin="round"/>`,
  "x-mark": `<path d="M6 6l12 12M18 6 6 18" stroke-linecap="round" stroke-linejoin="round"/>`,
  menu: `<path d="M4 6.5h16M4 12h16M4 17.5h16" stroke-linecap="round" stroke-linejoin="round"/>`,
  "chevron-down": `<path d="m6 9 6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/>`,
  sparkles: `<path d="M12 3.5 13.6 8.4 18.5 10l-4.9 1.6L12 16.5l-1.6-4.9L5.5 10l4.9-1.6L12 3.5ZM19 15l.75 2.25L22 18l-2.25.75L19 21l-.75-2.25L16 18l2.25-.75L19 15Z" stroke-linecap="round" stroke-linejoin="round"/>`,
  scale: `<path d="M12 3v18M7 7l-3.5 7a3.5 3.5 0 0 0 7 0L7 7ZM17 7l-3.5 7a3.5 3.5 0 0 0 7 0L17 7ZM4.5 7h5M14.5 7h5M8 21h8" stroke-linecap="round" stroke-linejoin="round"/>`,
  mail: `<rect x="3" y="5.5" width="18" height="13" rx="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="m4 7 8 6 8-6" stroke-linecap="round" stroke-linejoin="round"/>`,
  document: `<path d="M7 3.75h7l4 4V19.5A1.5 1.5 0 0 1 16.5 21h-9A1.5 1.5 0 0 1 6 19.5V5.25a1.5 1.5 0 0 1 1.5-1.5Z" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 3.75V8h4.25M9 12.5h6M9 15.5h6M9 18.5h4" stroke-linecap="round" stroke-linejoin="round"/>`,
  shield: `<path d="M12 3.5 5 6v5.5c0 4.5 3 7.7 7 9 4-1.3 7-4.5 7-9V6l-7-2.5Z" stroke-linecap="round" stroke-linejoin="round"/><path d="m9.25 12 1.9 1.9 3.6-3.9" stroke-linecap="round" stroke-linejoin="round"/>`,
} as const;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  class={className}
  aria-hidden="true"
  set:html={ICONS[name as keyof typeof ICONS]}
/>
