---
// ============================================================================
// ToolCard.astro
// ----------------------------------------------------------------------------
// The single reusable "tool preview" card used across the homepage, category
// pages, alternatives pages, and use-case roundups. Keeping this in one
// component means the tool-card visual style only ever needs to change in
// one place.
// ============================================================================
import ToolLogo from "./ToolLogo.astro";
import type { Tool } from "../lib/data";

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;
---

<a href={`/tools/${tool.slug}/`} class="card flex gap-4 p-5">
  <ToolLogo name={tool.name} slug={tool.slug} class="h-11 w-11 shrink-0 text-base" />
  <div class="min-w-0 flex-1">
    <div class="mb-1 flex items-start justify-between gap-2">
      <h3 class="truncate font-medium text-neutral-950">{tool.name}</h3>
      {
        tool.hasFreeTier ? (
          <span class="shrink-0 whitespace-nowrap rounded-full border border-neutral-200 px-2 py-0.5 text-xs text-neutral-600">
            Free tier
          </span>
        ) : (
          <span class="shrink-0 whitespace-nowrap rounded-full border border-neutral-200 px-2 py-0.5 text-xs text-neutral-400">
            Paid only
          </span>
        )
      }
    </div>
    <p class="mb-1 text-xs text-neutral-400">by {tool.maker}</p>
    <p class="line-clamp-2 text-sm text-neutral-600">{tool.tagline}</p>
  </div>
</a>
