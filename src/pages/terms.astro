---
// ============================================================================
// terms.astro
// ----------------------------------------------------------------------------
// Required legal page. Same caveat as privacy-policy.astro: this is a
// reasonable starting template, not a substitute for legal review.
// ============================================================================
import Layout from "../layouts/Layout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { SITE } from "../lib/site";

const title = `Terms of Use — ${SITE.name}`;
const description = `Terms and conditions for using ${SITE.name}.`;

// TODO: update this date whenever the terms text actually changes.
const lastUpdated = "2026-07-02";
---

<Layout title={title} description={description} path="/terms/">
  <Breadcrumbs crumbs={[{ name: "Home", path: "/" }, { name: "Terms of Use", path: "/terms/" }]} />
  <article class="mx-auto max-w-3xl px-5 py-10">
    <h1 class="mb-2 text-3xl font-semibold text-neutral-950">Terms of Use</h1>
    <p class="mb-8 text-xs text-neutral-400">Last updated: {lastUpdated}</p>

    <div class="space-y-4 text-neutral-700">
      <p>
        By accessing {SITE.name}, you agree to these Terms of Use.
        <!-- TODO: this is a starting template, not legal advice. Consider a generator
             like Termly, or a lawyer review, before launch. -->
      </p>

      <h2 class="!mt-8 text-xl font-semibold text-neutral-950">Content Accuracy</h2>
      <p>
        We make reasonable efforts to keep tool pricing, features, and comparisons accurate and
        up to date, but AI tools change frequently. Always verify current pricing and features on
        the official website of any tool before making a purchasing decision.
      </p>

      <h2 class="!mt-8 text-xl font-semibold text-neutral-950">No Warranty</h2>
      <p>
        This site is provided "as is" without warranties of any kind, express or implied. We are
        not responsible for any decisions made based on the information provided here.
      </p>

      <h2 class="!mt-8 text-xl font-semibold text-neutral-950">Affiliate Relationships</h2>
      <p>
        Some outbound links are affiliate links. See our
        <a href="/affiliate-disclosure/" class="text-neutral-950 underline underline-offset-2">Affiliate Disclosure</a>
        for details.
      </p>

      <h2 class="!mt-8 text-xl font-semibold text-neutral-950">Changes to These Terms</h2>
      <p>
        We may revise these Terms from time to time. Continued use of the site after changes
        constitutes acceptance of the revised Terms.
      </p>
    </div>
  </article>
</Layout>
